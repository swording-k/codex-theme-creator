{
  "name": "codex-theme-creator-app",
  "version": "0.1.3-beta.11",
  "description": "A local Codex Desktop theme library and creator for macOS and Windows.",
  "author": "Codex Theme Creator contributors",
  "private": true,
  "type": "module",
  "main": "main.mjs",
  "scripts": {
    "start": "electron .",
    "test": "node tests/desktop-entry.test.mjs",
    "dist": "electron-builder --mac dmg zip",
    "dist:mac": "electron-builder --mac dmg zip",
    "dist:win": "electron-builder --win nsis --x64 --arm64"
  },
  "build": {
    "appId": "com.swordingk.codexthemecreator",
    "productName": "Codex Theme Creator",
    "icon": "build/icon-chatgpt-theme.icns",
    "fileAssociations": [
      {
        "ext": "ctheme",
        "name": "Codex Theme",
        "description": "Codex Theme Creator package",
        "role": "Editor"
      }
    ],
    "asar": false,
    "generateUpdatesFilesForAllChannels": true,
    "publish": [
      {
        "provider": "github",
        "owner": "swording-k",
        "repo": "codex-theme-creator",
        "releaseType": "prerelease"
      }
    ],
    "files": [
      "main.mjs",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../theme-studio",
        "to": "theme-studio"
      },
      {
        "from": "../engine",
        "to": "engine"
      },
      {
        "from": "../scripts",
        "to": "scripts"
      },
      {
        "from": "../skills",
        "to": "skills"
      },
      {
        "from": "../dream-skin",
        "to": "dream-skin"
      },
      {
        "from": "build/tray-template.png",
        "to": "tray-template.png"
      }
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "Codex-Theme-Creator-${version}-${arch}.${ext}"
    },
    "dmg": {
      "title": "Codex Theme Creator"
    },
    "win": {
      "icon": "build/icon-chatgpt-theme.iconset/icon_256x256.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "artifactName": "Codex-Theme-Creator-Setup-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "build/installer.nsh",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Codex Theme Creator"
    }
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
